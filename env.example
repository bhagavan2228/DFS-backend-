# Copy to your deployment environment (do not commit real secrets).
# Spring Boot reads these as environment variables; names match application.properties.

# DATASOURCE_URL=jdbc:mysql://host:3306/dfs?useSSL=true&serverTimezone=UTC
# DATASOURCE_USERNAME=root
# DATASOURCE_PASSWORD=

# JWT_SECRET=  (min ~32 bytes for HS256; use a long random string)
# JWT_EXPIRATION_MS=86400000

# SERVER_PORT=8082

# JPA_DDL_AUTO=validate
# JPA_SHOW_SQL=false

# CORS_ALLOWED_ORIGIN_PATTERNS=https://your-frontend.example.com,http://localhost:3000

# SPRING_PROFILES_ACTIVE=prod
